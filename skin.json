{
	"name": "Whale",
	"author": ["Librewiki developers", "..."],
	"url": "https://github.com/gaon12/Whale",
	"descriptionmsg": "whale-desc",
	"namemsg": "skinname-whale",
	"license-name": "GPL-3.0-or-later",
	"type": "skin",
	"version": "1.13.9",
	"requires": {
		"MediaWiki": ">= 1.39.0"
	},
	"ValidSkinNames": {
		"whale": {
			"displayname": "Whale",
			"class": "SkinWhale",
			"args": [
				{
					"name": "whale",
					"bodyClasses": ["Whale", "width-size"],
					"bodyOnly": true,
					"responsive": true,
					"templateDirectory": "templates",
					"tempUserBanner": false,
					"styles": ["skins.whale.styles"]
				}
			]
		}
	},
	"MessagesDirs": {
		"Whale": ["i18n"]
	},
	"config": {
		"WhaleEnableLiveRC": true,
		"WhaleEnableSectionCollapse": true,
		"WhaleEnableFoldingBlocks": true,
		"WhaleEnableBlurredCategories": true,
		"WhaleEnableFloatingToc": true,
		"WhaleUseGravatar": true,
		"WhaleTheme": null,
		"WhalePrimaryColor": null,
		"WhaleSecondaryColor": null,
		"WhaleMainColor": "#4188F1",
		"WhaleSecondColor": null,
		"WhaleAdSetting": null,
		"WhaleOgLogo": null,
		"TwitterAccount": null,
		"NaverVerification": null,
		"WhaleMobileReplaceAd": false,
		"WhaleLiveRCArticleNamespaces": [0, 4, 10, 12, 14],
		"WhaleLiveRCTalkNamespaces": [1, 3, 5, 7, 9, 11, 13, 15],
		"WhaleLiveRCRefreshInterval": 60,
		"WhaleLiveRecentFixedHeight": true,
		"WhaleMaxRecent": 10,
		"WhaleEnableUserContributionGraph": true,
		"WhaleContributionGraphDays": 365,
		"WhaleContributionGraphNamespaces": null,
		"WhaleContributionGraphCacheTTL": 3600,
		"WhaleContributionGraphLevels": [1, 3, 6, 10],
		"WhaleEnableShortUrls": true,
		"WhaleShortUrlPathPrefix": "/s",
		"WhaleShortUrlRedirectStatus": 302,
		"WhaleEnableHeadingAnchors": true,
		"WhaleEnableReadingProgress": true,
		"WhaleEnableResponsiveTables": true,
		"WhaleEnableSortableTables": true,
		"WhaleEnableContentFontScale": true,
		"WhaleEnableAnonThemeToggle": true,
		"WhaleEnableImageLazyLoad": true,
		"WhaleMobileUserToolsPosition": "right"
	},
	"AvailableRights": [
		"blockads-header",
		"blockads-right",
		"blockads-belowarticle",
		"blockads-bottom"
	],
	"ResourceModules": {
		"skins.whale.styles": {
			"class": "MediaWiki\\ResourceLoader\\SkinModule",
			"features": {
				"interface": false,
				"toc": false,
				"content-media": true,
				"content-tables": true,
				"i18n-ordered-lists": true,
				"i18n-headings": true
			},
			"styles": {
				"less/default.less": {
					"media": "all"
				},
				"less/wiki.less": {
					"media": "all"
				},
				"less/only-mw.less": {
					"media": "all"
				},
				"less/wiki-table.less": {
					"media": "all"
				},
				"less/wikiedittor-whale.less": {
					"media": "all"
				},
				"less/extensions/RelatedArticles.less": {
					"media": "all"
				},
				"less/print.less": {
					"media": "print"
				}
			}
		},
		"skins.whale.common": {
			"scripts": "js/common.js"
		},
		"skins.whale.ads": {
			"scripts": "js/ads.js",
			"dependencies": "skins.whale.common"
		},
		"skins.whale.layoutjs": {
			"scripts": [
				"js/delay-scrolling.js",
				"js/index-button.js",
				"js/share-button.js",
				"js/layout.js"
			],
			"dependencies": ["mediawiki.cookie", "skins.whale.common"]
		},
		"skins.whale.headingAnchors": {
			"scripts": "js/heading-anchors.js",
			"messages": ["whale-heading-link-copied", "whale-heading-link-copy"],
			"dependencies": "skins.whale.common"
		},
		"skins.whale.tables": {
			"scripts": "js/table.js",
			"dependencies": "skins.whale.common"
		},
		"skins.whale.shortUrl": {
			"scripts": "js/short-url.js",
			"messages": ["whale-short-url-copied"],
			"dependencies": "skins.whale.common"
		},
		"skins.whale.themeToggle": {
			"scripts": "js/theme-toggle.js",
			"messages": ["whale-theme-toggle-light", "whale-theme-toggle-dark"],
			"dependencies": ["mediawiki.cookie", "skins.whale.common"]
		},
		"skins.whale.lazyImages": {
			"scripts": "js/lazy-images.js",
			"dependencies": "skins.whale.common"
		},
		"skins.whale.liverc": {
			"scripts": "js/live-recent.js",
			"messages": ["whale-feed-new"],
			"dependencies": ["mediawiki.util", "skins.whale.common"]
		},
		"skins.whale.loginjs": {
			"scripts": "js/login-request.js",
			"dependencies": "skins.whale.common"
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteSkinPath": "Whale"
	},
	"ResourceModuleSkinStyles": {
		"whale": {
			"+ext.relatedArticles.readMore": "less/extensions/RelatedArticles.less",
			"+ext.echo.ui": "less/extensions/Echo.less",
			"+mediawiki.action.view.filepage": "less/skinStyles/mediawiki.action.view.filepage.less",
			"+mediawiki.special.preferences.styles": "less/skinStyles/mediawiki.special.preferences.styles.less"
		}
	},
	"AutoloadClasses": {
		"SkinWhale": "SkinWhale.php",
		"WhaleRenderer": "WhaleRenderer.php",
		"WhaleHooks": "WhaleHooks.php",
		"WhaleShortUrl": "WhaleShortUrl.php",
		"SpecialWhaleShortUrl": "SpecialWhaleShortUrl.php"
	},
	"SpecialPages": {
		"WhaleShortUrl": "SpecialWhaleShortUrl"
	},
	"DefaultUserOptions": {
		"whale-reading-progress": true,
		"whale-heading-anchors": true,
		"whale-responsive-tables": true,
		"whale-sortable-tables": true,
		"whale-content-font-scale": "normal",
		"whale-user-contribution-graph": true,
		"whale-short-url": true,
		"whale-lazy-images": true,
		"whale-mobile-user-tools-right": true
	},
	"Hooks": {
		"GetPreferences": "WhaleHooks::onGetPreferences",
		"OutputPageBodyAttributes": "WhaleHooks::onOutputPageBodyAttributes",
		"OutputPageBeforeHTML": "WhaleHooks::onOutputPageBeforeHTML",
		"ParserBeforePreprocess": "WhaleHooks::onParserBeforePreprocess"
	},
	"manifest_version": 1
}

{
	"name": "Whale",
	"author": ["Librewiki developers", "..."],
	"url": "https://github.com/librewiki/whale-skin",
	"descriptionmsg": "whale-desc",
	"namemsg": "skinname-whale",
	"license-name": "GPL-3.0-or-later",
	"type": "skin",
	"version": "1.13.9",
	"requires": {
		"MediaWiki": ">= 1.39.0"
	},
	"ValidSkinNames": {
		"whale": {
			"displayname": "Whale",
			"class": "SkinWhale",
			"args": [
				{
					"name": "whale",
					"bodyClasses": ["Whale", "width-size"],
					"bodyOnly": true,
					"responsive": true,
					"templateDirectory": "templates",
					"tempUserBanner": false,
					"styles": ["skins.whale.styles"]
				}
			]
		}
	},
	"MessagesDirs": {
		"Whale": ["i18n"]
	},
	"config": {
		"WhaleEnableLiveRC": true,
		"WhaleUseGravatar": true,
		"WhaleMainColor": "#4188F1",
		"WhaleSecondColor": null,
		"WhaleAdSetting": null,
		"WhaleOgLogo": null,
		"TwitterAccount": null,
		"NaverVerification": null,
		"WhaleMobileReplaceAd": false,
		"WhaleLiveRCArticleNamespaces": [0, 4, 10, 12, 14],
		"WhaleLiveRCTalkNamespaces": [1, 3, 5, 7, 9, 11, 13, 15],
		"WhaleMaxRecent": 10
	},
	"AvailableRights": [
		"blockads-header",
		"blockads-right",
		"blockads-belowarticle",
		"blockads-bottom"
	],
	"ResourceModules": {
		"skins.whale.styles": {
			"class": "MediaWiki\\ResourceLoader\\SkinModule",
			"features": {
				"interface": false,
				"toc": false,
				"content-media": true,
				"content-tables": true,
				"i18n-ordered-lists": true,
				"i18n-headings": true
			},
			"styles": {
				"bootstrap/css/bootstrap.min.css": {
					"media": "all"
				},
				"css/default.css": {
					"media": "all"
				},
				"css/default_mobile.css": {
					"media": "all"
				},
				"css/wiki.css": {
					"media": "all"
				},
				"css/only-mw.css": {
					"media": "all"
				},
				"css/wiki-table.css": {
					"media": "all"
				},
				"css/wikiedittor-whale.css": {
					"media": "all"
				},
				"less/extensions/RelatedArticles.less": {
					"media": "all"
				},
				"css/print.css": {
					"media": "print"
				}
			}
		},
		"skins.whale.ads": {
			"scripts": "js/ads.js"
		},
		"skins.whale.layoutjs": {
			"scripts": [
				"js/delay-scrolling.js",
				"js/disable-notice.js",
				"js/share-button.js",
				"js/layout.js",
				"js/table.js",
				"js/scroll-button.js"
			],
			"dependencies": "mediawiki.cookie"
		},
		"skins.whale.liverc": {
			"scripts": "js/live-recent.js",
			"messages": ["whale-feed-new"],
			"dependencies": "mediawiki.util"
		},
		"skins.whale.loginjs": {
			"scripts": "js/login-request.js",
			"dependencies": "mediawiki.util"
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteSkinPath": "Whale"
	},
	"ResourceModuleSkinStyles": {
		"whale": {
			"+ext.relatedArticles.readMore": "less/extensions/RelatedArticles.less",
			"+ext.echo.ui": "css/extensions/Echo.css",
			"+mediawiki.action.view.filepage": "css/skinStyles/mediawiki.action.view.filepage.css",
			"+mediawiki.special.preferences.styles": "css/skinStyles/mediawiki.special.preferences.styles.css"
		}
	},
	"AutoloadClasses": {
		"SkinWhale": "SkinWhale.php",
		"WhaleTemplate": "WhaleTemplate.php",
		"WhaleHooks": "WhaleHooks.php"
	},
	"Hooks": {
		"GetPreferences": "WhaleHooks::onGetPreferences",
		"OutputPageBodyAttributes": "WhaleHooks::onOutputPageBodyAttributes"
	},
	"manifest_version": 1
}

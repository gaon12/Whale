{
	"name": "Freedom",
	"author": [
		"Librewiki developers",
		"..."
	],
	"url": "https://github.com/librewiki/freedom-skin",
	"descriptionmsg": "freedom-desc",
	"namemsg": "skinname-freedom",
	"license-name": "GPL-3.0-or-later",
	"type": "skin",
	"version": "2.0.0",
	"requires": {
		"MediaWiki": ">= 1.39.0"
	},
	"ValidSkinNames": {
		"freedom": {
			"displayname": "Freedom",
			"class": "SkinFreedom",
			"args": [ {
				"name": "freedom",
				"bodyClasses": [ "Freedom" ],
				"responsive": true,
				"template": "skin",
				"styles": [
					"skins.freedom.styles"
				]
			} ]
		}
	},
	"MessagesDirs": {
		"Freedom": [
			"i18n"
		]
	},
	"config": {
		"FreedomEnableLiveRC": { "value": true },
		"FreedomUseGravatar": { "value": false },
		"FreedomMainColor": { "value": "#4188F1" },
		"FreedomSecondColor": { "value": null },
		"FreedomAdSetting": { "value": null },
		"FreedomOgLogo": { "value": null },
		"FreedomTwitterAccount": { "value": null },
		"FreedomNaverVerification": { "value": null },
		"FreedomMobileReplaceAd": { "value": false },
		"FreedomLiveRCArticleNamespaces": { "value": [ 0, 4, 10, 12, 14 ] },
		"FreedomLiveRCTalkNamespaces": { "value": [ 1, 3, 5, 7, 9, 11, 13, 15 ] },
		"FreedomMaxRecent": { "value": 10 },
		"FreedomDefaultWidth": { "value": "1200px" },
		"FreedomShowReadingProgressBar": { "value": true },
		"FreedomCollapsibleSections": { "value": true },
		"FreedomStickyTOC": { "value": true },
		"FreedomShowCopyButtons": { "value": true }
	},
	"AvailableRights": [
		"blockads-header",
		"blockads-right",
		"blockads-belowarticle",
		"blockads-bottom"
	],
	"ResourceModules": {
		"skins.freedom.styles": {
			"class": "MediaWiki\\ResourceLoader\\SkinModule",
			"features": {
				"interface": true,
				"toc": true,
				"content-media": true,
				"content-tables": true,
				"i18n-ordered-lists": true,
				"i18n-headings": true
			},
			"styles": {
				"css/freedom.css": {
					"media": "all"
				}
			}
		},
		"skins.freedom.js": {
			"scripts": [
				"js/freedom.js"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteSkinPath": "Freedom"
	},
	"AutoloadClasses": {
		"SkinFreedom": "SkinFreedom.php",
		"FreedomHooks": "FreedomHooks.php",
		"FreedomMenuParser": "includes/FreedomMenuParser.php"
	},
	"Hooks": {
		"GetPreferences": "FreedomHooks::onGetPreferences",
		"OutputPageBodyAttributes": "FreedomHooks::onOutputPageBodyAttributes"
	},
	"manifest_version": 2
}

{
	"name": "librewiki/whale-mw-skin",
	"description": "Whale MediaWiki Skin",
	"license": "GPL-3.0-or-later",
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": ">=0.9.0",
		"phpstan/phpstan": "^2.2"
	},
	"scripts": {
		"analyse": [
			"php vendor/phpstan/phpstan/phpstan.phar analyse --level=max"
		],
		"test": [
			"php vendor/squizlabs/php_codesniffer/bin/phpcs -p -s",
			"@test:folding",
			"@test:short-url",
			"@test:sections",
			"@test:avatar",
			"@test:navbar"
		],
		"test:folding": [
			"php scripts/check-folding.php"
		],
		"test:short-url": [
			"php scripts/check-short-url.php"
		],
		"test:sections": [
			"php scripts/check-section-decoration.php"
		],
		"test:avatar": [
			"php scripts/check-avatar.php"
		],
		"test:navbar": [
			"php scripts/check-navbar.php"
		],
		"fix": "php vendor/squizlabs/php_codesniffer/bin/phpcbf"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"dicebear/core": "^10.0",
		"dicebear/styles": "^10.1"
	}
}

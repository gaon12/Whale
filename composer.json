{
	"name": "librewiki/whale-mw-skin",
	"version": "1.13.9",
	"description": "Whale MediaWiki Skin",
	"license": "GPL-3.0-or-later",
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": ">=0.9.0",
		"phpstan/phpstan": "^2.2"
	},
	"scripts": {
		"analyse": [
			"phpstan analyse --level=max"
		],
		"test": [
			"phpcs -p -s",
			"@test:folding",
			"@test:avatar",
			"@test:navbar"
		],
		"test:folding": [
			"php scripts/check-folding.php"
		],
		"test:avatar": [
			"php scripts/check-avatar.php"
		],
		"test:navbar": [
			"php scripts/check-navbar.php"
		],
		"fix": "phpcbf"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"dicebear/core": "^10.0",
		"dicebear/styles": "^10.1"
	}
}

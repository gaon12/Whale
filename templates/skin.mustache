<header>
	<div class="whale-nav-wrapper whale-navbar-fixed">
		{{>Nav}}
	</div>
</header>
<section>
	<div class="content-wrapper{{^has-whale-sidebar}} whale-content-wrapper-no-sidebar{{/has-whale-sidebar}}">
		{{#has-whale-sidebar}}
			<aside>
				<div class="whale-sidebar">
					{{#has-whale-site-notice}}
						<div class="whale-sidebar-notice" role="alert">
							<button type="button" class="whale-notice-close" data-whale-dismiss="notice" aria-label="{{whale-close-label}}">
								<span aria-hidden="true">&times;</span>
							</button>
							{{{ html-whale-site-notice }}}
						</div>
					{{/has-whale-site-notice}}
					<div class="live-recent-wrapper">
						{{>LiveRecent}}
					</div>
					{{{ html-whale-right-ad }}}
				</div>
			</aside>
		{{/has-whale-sidebar}}
		<div class="whale-content{{^has-whale-sidebar}} whale-content-no-sidebar{{/has-whale-sidebar}}">
			<div class="whale-content-header{{#has-whale-sidebar}} whale-content-header-with-sidebar{{/has-whale-sidebar}}">
				{{#has-whale-site-notice}}
					<div class="whale-notice" role="alert">
						<button type="button" class="whale-notice-close" data-whale-dismiss="notice" aria-label="{{whale-close-label}}">
							<span aria-hidden="true">&times;</span>
						</button>
						{{{ html-whale-site-notice }}}
					</div>
				{{/has-whale-site-notice}}
				{{{ html-whale-header-ad }}}
				{{>ContentTools}}
				<div class="title">
					<h1>{{{ html-title }}}</h1>
				</div>
				<div class="contentSub" {{{ html-user-language-attributes }}}>
					{{{ html-subtitle }}}
				</div>
			</div>
			<div class="whale-content-main" id="content">
				{{#html-user-message}}
					<div class="usermessage">{{{ html-user-message }}}</div>
				{{/html-user-message}}
				{{>UserContributionGraph}}
				{{{ html-categories }}}
				<article class="mw-body-content" id="mw-content-text">
					{{#has-whale-not-found}}
						{{#data-whale-not-found}}
							<div class="whale-not-found">
								<div class="whale-not-found-icon">{{{ html-icon }}}</div>
								<div class="whale-not-found-copy">
									<p class="whale-not-found-kicker">404</p>
									<h2>{{title}}</h2>
									<p>{{description}}</p>
									<div class="whale-not-found-actions">{{{ html-actions }}}</div>
								</div>
							</div>
						{{/data-whale-not-found}}
					{{/has-whale-not-found}}
					{{^has-whale-not-found}}
						{{{ html-body-content }}}
					{{/has-whale-not-found}}
				</article>
				{{{ html-whale-belowarticle-ad }}}
			</div>
			{{#has-whale-mobile-live-recent}}
				<div class="mobile-live-recent-wrapper">
					{{>LiveRecentMobile}}
				</div>
			{{/has-whale-mobile-live-recent}}
			<footer>
				<div class="whale-footer">
					{{{ html-after-content }}}
					{{{ html-whale-bottom-ad }}}
					{{#has-whale-mobile-ad}}
						<div class="mobile-ads"></div>
					{{/has-whale-mobile-ad}}
					{{>Footer}}
				</div>
			</footer>
			<div id="whale-bottombtn">
				<div class="whale-dropdown whale-bottom-tools">
					<button type="button" class="scroll-button whale-tools-toggle" data-whale-toggle="dropdown" aria-label="{{whale-tools-label}}" title="{{whale-tools-label}}" aria-haspopup="true" aria-expanded="false">{{{ html-whale-tools-icon }}}<span class="whale-bottom-tools-toggle-label">{{whale-tools-label}}</span></button>
					<div class="whale-dropdown-menu whale-bottom-tools-menu" role="menu">
						{{#data-whale-theme-toggle}}
							<button type="button" class="whale-dropdown-item whale-theme-toggle" data-whale-theme-toggle aria-label="{{label}}" title="{{label}}" aria-pressed="{{aria-pressed}}">
								<span class="whale-theme-toggle-icon whale-theme-toggle-when-light">{{{ html-moon-icon }}}</span>
								<span class="whale-theme-toggle-icon whale-theme-toggle-when-dark">{{{ html-sun-icon }}}</span>
								<span class="whale-tools-label" data-whale-theme-toggle-label>{{label}}</span>
							</button>
						{{/data-whale-theme-toggle}}
						{{#data-whale-short-url}}
							{{#has-short-url}}
								<button type="button" class="whale-dropdown-item whale-short-url-open" data-whale-toggle="modal" data-whale-target="#whale-short-url-modal">{{{ html-icon }}}<span class="whale-tools-label">{{button-label}}</span></button>
							{{/has-short-url}}
						{{/data-whale-short-url}}
					</div>
				</div>
				{{#has-whale-section-tools}}
					<button type="button" class="scroll-button" id="whale-scrolltoc" aria-label="{{whale-scroll-toc-label}}" title="{{whale-scroll-toc-label}}">{{{ html-whale-scroll-toc-icon }}}</button>
				{{/has-whale-section-tools}}
				<button type="button" class="scroll-button" id="whale-scrollup" aria-label="{{whale-scroll-up-label}}" title="{{whale-scroll-up-label}}">{{{ html-whale-scroll-up-icon }}}</button>
				<button type="button" class="scroll-button" id="whale-scrolldown" aria-label="{{whale-scroll-down-label}}" title="{{whale-scroll-down-label}}">{{{ html-whale-scroll-down-icon }}}</button>
			</div>
		</div>
	</div>
</section>
{{{ html-whale-adsense-script }}}
{{>LoginModal}}
{{>ShortUrlModal}}
{{>ExternalLinkModal}}
{{{ html-whale-debughtml }}}
{{{ html-scripts }}}
{{{ html-whale-rocket-loader-recovery }}}

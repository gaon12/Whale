{{#data-whale-external-link-warning}}
<div class="whale-modal whale-modal-fade whale-external-link-modal" id="whale-external-link-modal" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="whale-external-link-modal-label" aria-hidden="true">
	<div class="whale-modal-dialog whale-modal-sm">
		<div class="whale-modal-content">
			<div class="whale-modal-header">
				<button type="button" class="whale-modal-close" data-whale-dismiss="modal" aria-label="{{close-label}}"><span aria-hidden="true">&times;</span></button>
				<h4 class="whale-modal-title" id="whale-external-link-modal-label">{{title}}</h4>
			</div>
			<div class="whale-modal-body">
				<p class="whale-external-link-description">{{description}}</p>
				<div class="whale-external-link-url" data-whale-external-url></div>
				<button type="button" class="whale-btn whale-btn-secondary whale-external-link-toggle" data-whale-external-toggle hidden>{{show-decoded-label}}</button>
				<div class="whale-external-link-actions">
					<button type="button" class="whale-btn whale-btn-secondary" data-whale-dismiss="modal">{{cancel-label}}</button>
					<a class="whale-btn whale-btn-primary whale-external-link-continue" data-whale-external-continue rel="noopener noreferrer">{{continue-label}}</a>
				</div>
			</div>
		</div>
	</div>
</div>
{{/data-whale-external-link-warning}}
